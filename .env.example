# ════════════════════════════════════════════════════════════════════════════
# LangGraph Advanced — 환경 설정 예시
# 이 파일을 .env 로 복사하여 실제 값을 채워주세요.
# ════════════════════════════════════════════════════════════════════════════

# ── LLM (연결 정보만 — 모델·파라미터는 API 파라미터 또는 Config DB로 제어) ──
# 지원: ollama | vllm | triton
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434        # Ollama / vLLM / Triton 엔드포인트
# LLM_BASE_URL=http://host.docker.internal:11434  # Docker 컨테이너에서 실행 시

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=your_id
NEO4J_PASSWORD=your_password

# ── Milvus ────────────────────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300.0

# ── Execution ─────────────────────────────────────────────────────────────────
RECURSION_LIMIT=10
SENTENCE_TRANSFORMER_MODEL=snunlp/KR-SBERT-V40K-klueNLI-augSTS

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG                             # DEBUG | INFO | WARNING | ERROR
ENVIRONMENT=development                    # development | staging | production
API_HOST=0.0.0.0
API_PORT=8000
